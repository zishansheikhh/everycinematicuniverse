# Required for poster and release-year lookup.
OMDB_API_KEY=your_omdb_api_key_here

# Coolify/Next runtime defaults.
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
PORT=3000
HOSTNAME=0.0.0.0

# Persistent cache location. In Coolify, mount a volume to /app/.cache
# if you want OMDB results to survive container rebuilds.
OMDB_CACHE_FILE=/app/.cache/omdb-cache.json
OMDB_CACHE_TTL_SECONDS=31536000
